# Auto-detect text files and perform LF normalization
* text=auto

# Denote files that are truly binary and should not be modified
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.keystore binary

# Explicitly declare text files
*.kt text
*.java text
*.xml text
*.gradle text
*.gradle.kts text
*.properties text
*.txt text
*.md text
*.json text

# Declare files that should always use CRLF line endings
*.bat text eol=crlf
